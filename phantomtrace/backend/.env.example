# PhantomTrace Backend Environment Variables
# Copy this file to .env and fill in the values

# Database (default: SQLite local file — fine for testing and small deployments)
DATABASE_URL=sqlite:///./phantomtrace.db

# Optional: VirusTotal API key for URL reputation checks (free tier: 4 req/min)
# Get yours at https://www.virustotal.com/gui/sign-in
VIRUSTOTAL_API_KEY=

# Optional: AbuseIPDB API key for IP reputation
# Get yours at https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=
