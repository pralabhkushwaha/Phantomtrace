# PhantomTrace Backend Environment Variables
# Copy this file to .env and fill in the values

DATABASE_URL=sqlite:///./phantomtrace.db

# ── Free API Keys (Highly Recommended — all have free tiers) ─────────────

# VirusTotal — https://www.virustotal.com/gui/sign-in  (free: 4 req/min)
VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/api  (free: 1000 req/day)
ABUSEIPDB_API_KEY=

# AlienVault OTX — https://otx.alienvault.com  (free, unlimited)
OTX_API_KEY=

# urlscan.io — https://urlscan.io/user/signup  (free: 100 req/day)
URLSCAN_API_KEY=

# Google Safe Browsing — https://developers.google.com/safe-browsing  (free)
GOOGLE_SAFE_BROWSING_API_KEY=

# Numverify (phone number validation) — https://numverify.com  (free: 100/month)
NUMVERIFY_API_KEY=

# WhoisXML API — https://whoisxmlapi.com  (free: 500/month)
WHOISXML_API_KEY=

# Shodan — https://account.shodan.io  (free account; $49/yr for scan API)
SHODAN_API_KEY=
